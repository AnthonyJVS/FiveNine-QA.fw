# ──────────────────────────────────────────────
# Environment Configuration Template
# ──────────────────────────────────────────────
# Copy this file to .env.dev, .env.staging, or .env.prod
# and fill in the values for your environment.
#
# Usage:
#   cp .env.example .env.dev
#   set ENV=dev    (Windows)
#   export ENV=dev (macOS/Linux)
# ──────────────────────────────────────────────

ENV=dev
BASE_URL=https://your-target-site.com
API_BASE_URL=https://your-target-site.com/api

# Browser
BROWSER=chromium
HEADLESS=true
SLOW_MO=0
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720

# Timeouts (ms for browser, seconds for API)
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=30000
API_TIMEOUT=30

# Artifacts
SCREENSHOT_DIR=screenshots
LOG_DIR=logs
REPORT_DIR=reports

# Test User (leave empty — framework generates dynamic users via Faker)
# TEST_USER_EMAIL=
# TEST_USER_PASSWORD=
